SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Vakıfbank MPI + VPOS (doğrudan 3D Sanal POS) — Netlify: Site settings → Environment variables
# Şifreyi yalnızca panelde tutun; repoya commit etmeyin.
# VAKIF_INIT=test ile önce test ortamı; canlıda VAKIF_INIT=prod
VAKIF_INIT=test
VAKIF_HOST_MERCHANT_ID=
VAKIF_MERCHANT_PASSWORD=
VAKIF_HOST_TERMINAL_ID=
# MPI oturum çerezi / yedek notlar için (önerilir; yoksa şifre türevi kullanılır)
VAKIF_MPI_SESSION_SECRET=
# Geçici: enrollment hata yanıtında supportCopy (maskeli) + Netlify log satırı MPI_FAIL_JSON — iş bitince kapatın
# VAKIF_MPI_CLIENT_DEBUG=1
# Yalnızca test: odeme.html?mpi_test=1 ile müşteri formu olmadan kart-only MPI — iş bitince kaldırın
# VAKIF_MPI_TEST_MODE=1

# Yerel MPI enrollment (Netlify yok): npm run test:mpi — gerçek PAN'ı repoya yazmayın
# TEST_PAN=
# TEST_EXPIRY_YYMM=
# TEST_AMOUNT=2490.00
# TEST_MPI_DUMP_RAW=1
# Callback: SuccessURL / FailURL için site kökü (sonunda / olmadan)
SITE_URL=https://finskor.tr

# İsteğe bağlı: QuotaGuard Static (sabit çıkış IP) — panelde verilen tam proxy URL
# QUOTAGUARDSTATIC_URL=http://...
