SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
# İsteğe bağlı: tam URL (host çıkarımı)
# SUPABASE_URL=https://xxxx.supabase.co

# Kart (MPI async): mpi_enroll_jobs tablosu — Supabase SQL migration 20260403120000_mpi_enroll_jobs.sql + Netlify’da SERVICE_KEY şart
# Supabase REST (sbRequest) süre sınırı ms — varsayılan 25000
# SB_HTTPS_TIMEOUT_MS=25000

# Vakıfbank MPI + VPOS (doğrudan 3D Sanal POS) — Netlify: Site settings → Environment variables
# Şifreyi yalnızca panelde tutun; repoya commit etmeyin.
# VAKIF_INIT=test ile önce test ortamı; canlıda VAKIF_INIT=prod
VAKIF_INIT=test
VAKIF_HOST_MERCHANT_ID=
VAKIF_MERCHANT_PASSWORD=
VAKIF_HOST_TERMINAL_ID=
# Varsayılan MPI/VPOS: HTTPS 443 (:8443 yok). Banka özel :4443 URL verdiyse override:
# VAKIF_MPI_ENROLL_URL_TEST=
# VAKIF_MPI_ENROLL_URL_PROD=
# İsteğe bağlı: ACS formundaki TermUrl (startThreeDFlow) farklıysa
# VAKIF_MPI_START_THREED_FLOW_TEST=
# VAKIF_MPI_START_THREED_FLOW_PROD=
# MPI oturum çerezi / yedek notlar için (önerilir; yoksa şifre türevi kullanılır)
VAKIF_MPI_SESSION_SECRET=
# Geçici: enrollment hata yanıtında supportCopy (maskeli) + Netlify log satırı MPI_FAIL_JSON — iş bitince kapatın
# VAKIF_MPI_CLIENT_DEBUG=1
# Yalnızca test: odeme.html?mpi_test=1 ile müşteri formu olmadan kart-only MPI — iş bitince kaldırın
# VAKIF_MPI_TEST_MODE=1

# Yerel MPI enrollment (Netlify yok): npm run test:mpi — gerçek PAN'ı repoya yazmayın
# TEST_PAN=
# TEST_EXPIRY_YYMM=
# TEST_AMOUNT=2490.00
# TEST_MPI_DUMP_RAW=1
# Callback: SuccessURL / FailURL için site kökü (sonunda / olmadan)
SITE_URL=https://finskor.tr

# İsteğe bağlı: QuotaGuard Static (sabit çıkış IP) — panelde verilen tam proxy URL
# (Kod: https-proxy-agent + Node https — Netlify’da undici ProxyAgent yerine)
# İsteğe bağlı: VAKIF_HTTPS_TIMEOUT_MS=55000
# Banka yanıtı HTML + başlık "Request Rejected" ise çoğunlukla IP whitelist; bu proxy şart olabilir.
# QUOTAGUARDSTATIC_URL=http://...
# VAKIF_PROXY_FAIL_CLOSED=1 → proxy URL var ama agent yoksa MPI hata (varsayılan: doğrudan çıkış + log uyarısı).
# VAKIF_MPI_ENROLL_INCLUDE_TERMINAL=1
# VAKIF_REQUIRE_EGRESS_PROXY=1
