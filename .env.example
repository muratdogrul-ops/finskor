SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
# İsteğe bağlı: tam URL (host çıkarımı)
# SUPABASE_URL=https://xxxx.supabase.co

# Kart (MPI async kuyruk): varsayılan Netlify Blobs. Geri alma: MPI_ENROLL_JOB_STORE=supabase (+ Supabase mpi_enroll_jobs migration 20260403120000 + SERVICE_KEY)
# MPI_ENROLL_JOB_STORE=blobs
# MPI_ENROLL_BLOBS_STORE=mpi-enroll-jobs
# Background function’da Blobs için (önerilir): Netlify UI → Personal access token → NETLIFY_AUTH_TOKEN
# NETLIFY_AUTH_TOKEN=
# Supabase REST (sbRequest) süre sınırı ms — varsayılan 25000
# SB_HTTPS_TIMEOUT_MS=25000

# Vakıfbank MPI + VPOS (doğrudan 3D Sanal POS) — Netlify: Site settings → Environment variables
# Şifreyi yalnızca panelde tutun; repoya commit etmeyin.
# VAKIF_INIT=test ile önce test ortamı; canlıda VAKIF_INIT=prod
VAKIF_INIT=test
VAKIF_HOST_MERCHANT_ID=
VAKIF_MERCHANT_PASSWORD=
VAKIF_HOST_TERMINAL_ID=
# MPI/VPOS: Varsayılan canlı uçlar :8443 (banka teyidi). Port/URL değişimi: VAKIF_HTTP_API_PORT veya tam URL env.
# postXml: varsayılan prmstr + application/x-www-form-urlencoded. Ham XML: VAKIF_POSTXML_FORCE_RAW=1
# VAKIF_POSTXML_FORCE_RAW=
# WAF denerken isteğe bağlı User-Agent (boşsa FinSkor-MPI/1.0)
# VAKIF_HTTP_USER_AGENT=
# VAKIF_HTTP_API_PORT=
# VAKIF_MPI_ENROLL_URL_TEST=
# VAKIF_MPI_ENROLL_URL_PROD=
# İsteğe bağlı: ACS formundaki TermUrl (startThreeDFlow) farklıysa
# VAKIF_MPI_START_THREED_FLOW_TEST=
# VAKIF_MPI_START_THREED_FLOW_PROD=
# Banka erişim testi: GET /.netlify/functions/vakif-connectivity-probe (?ping=1 | parametresiz kısa | ?full=1)
# Ücretsiz Netlify ~10s: varsayılan kısa prob. Uzun/tam: VAKIF_CONNECTIVITY_LONG=1 + Pro timeout önerilir. Yardım: /finskor-connectivity-yardim.json
# VAKIF_CONNECTIVITY_PROBE_SECRET=
# VAKIF_CONNECTIVITY_LONG=1
# VAKIF_CONNECTIVITY_PROBE_MS=12000
# VAKIF_CONNECTIVITY_RACE_MS=55000
# VPOS Sale — varsayılan canlı :8443; farklı host/port için VAKIF_VPOS_URL_* tam URL.
# VAKIF_VPOS_URL_TEST=
# VAKIF_VPOS_URL_PROD=
# VPOS Expiry: oturum YYMM iken banka YYYYMM istiyorsa (PDF 1052 vb.)
# VAKIF_VPOS_EXPIRY_YYYYMM=1
# ECI: PARes’teki değer + gerekirse Status (Y/A) + marka eşlemesi — auto | pares_only | map_only
# VAKIF_VPOS_ECI_STRATEGY=auto
# 1127: 3D sonrası Pan/tutar göndermeden satış (yalnızca ECI+CAVV dolu iken etkili)
# VAKIF_VPOS_3DS_OMIT_CARD_FIELDS=1
# VPOS 3D satış: cihaz kaynağı (1121 raporları için); kılavuz kodunu bankadan teyit edin. Göndermeyi kapatmak: VAKIF_VPOS_OMIT_TRANSACTION_DEVICE_SOURCE=1
# VAKIF_VPOS_TRANSACTION_DEVICE_SOURCE=0
# MpiTransactionId + VerifyEnrollmentRequestId birlikte mi tek mi: both (varsayılan) | mpi_only | verify_only
# VAKIF_VPOS_MPI_XML_STYLE=both
# MPI oturum çerezi / yedek notlar için (önerilir; yoksa şifre türevi kullanılır)
VAKIF_MPI_SESSION_SECRET=
# www + apex aynı çerez: boş bırakılırsa SITE_URL’den apex türetilir (netlify.app hariç). Zorunlu override: MPI_SESSION_COOKIE_DOMAIN=finskor.tr
# MPI_SESSION_COOKIE_DOMAIN=
# Geçici: enrollment hata yanıtında supportCopy (maskeli) + Netlify log satırı MPI_FAIL_JSON — iş bitince kapatın
# VAKIF_MPI_CLIENT_DEBUG=1
# Yalnızca test: odeme.html?mpi_test=1 ile müşteri formu olmadan kart-only MPI — iş bitince kaldırın
# VAKIF_MPI_TEST_MODE=1

# Yerel MPI enrollment (Netlify yok): npm run test:mpi — gerçek PAN'ı repoya yazmayın
# TEST_PAN=
# TEST_EXPIRY_YYMM=
# TEST_AMOUNT=2490.00
# TEST_MPI_DUMP_RAW=1
# Callback: SuccessURL / FailURL için site kökü (sonunda / olmadan)
SITE_URL=https://finskor.tr

# İsteğe bağlı: QuotaGuard Static (sabit çıkış IP) — panelde verilen tam proxy URL
# (Kod: https-proxy-agent + Node https — Netlify’da undici ProxyAgent yerine)
# İsteğe bağlı: VAKIF_HTTPS_TIMEOUT_MS=55000
# Banka yanıtı HTML + başlık "Request Rejected" ise çoğunlukla IP whitelist; bu proxy şart olabilir.
# QUOTAGUARDSTATIC_URL=http://...
# VAKIF_PROXY_FAIL_CLOSED=1 → proxy URL var ama agent yoksa MPI hata (varsayılan: doğrudan çıkış + log uyarısı).
# VAKIF_MPI_ENROLL_INCLUDE_TERMINAL=1
# VAKIF_REQUIRE_EGRESS_PROXY=1
