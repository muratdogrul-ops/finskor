# Kopyalayıp .env yapın; üretimde sadece secret yönetimi (Vault/K8s) kullanın.
NODE_ENV=development
PORT=3000

# JWT (zorunlu; compose içine yazmayın)
JWT_SECRET=degistir_uzun_rastgele_anahtar
JWT_EXPIRES_IN=7d

# CORS, virgülle
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=insaat_erp
DB_USER=erp_user
DB_PASSWORD=guvenli_sifre

# Düzey: debug | info | warn | error
LOG_LEVEL=info

# Smoke
# SMOKE_BASE=http://127.0.0.1:3000

# Masaüstü (Vite) — frontend .env.electron: VITE_API_BASE=http://127.0.0.1:3000
# Backend CORS; Origin: null (Electron) izinli.
